{
  "entities": {
    "admins": {
      "title": "Admins",
      "description": "Whitelisted admin users for DanfoDrive",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Supabase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "Admin email address (must be @gmail.com)" },
        "name": { "type": "string", "description": "Admin full name" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": "admins",
      "description": "Collection of whitelisted admin users"
    }
  }
}
